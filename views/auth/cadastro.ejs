<!DOCTYPE html>
<!DOCTYPE html>
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contrataê - Cadastro</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { 
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; 
            background: #121212; 
            min-height: 100vh; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            padding-bottom: 80px; 
        }
        
        .auth-container { width: 100%; max-width: 450px; padding: 20px; }
        .auth-card { 
            background: #1e1e1e; 
            border-radius: 12px; 
            box-shadow: 0 10px 40px rgba(0,0,0,0.5); 
            padding: 40px; 
            border: 1px solid #333;
        }
        
        .auth-header { text-align: center; margin-bottom: 40px; }
        .auth-header h1 { font-size: 32px; color: #ffa500; margin-bottom: 10px; font-weight: 800; }
        .auth-header p { color: #ccc; font-size: 14px; }
        
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: #fff; font-size: 14px; }
        .form-group input, .form-group select { 
            width: 100%; 
            padding: 12px 15px; 
            border: 1px solid #444; 
            border-radius: 8px; 
            font-size: 14px; 
            transition: 0.3s; 
            background: #2c2c2c;
            color: #fff;
        }
        .form-group input:focus, .form-group select:focus { outline: none; border-color: #ffa500; box-shadow: 0 0 0 3px rgba(255,165,0,0.1); }
        
        .password-wrapper { position: relative; }
        .toggle-password { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #999; }
        
        .btn { 
            width: 100%; 
            padding: 12px; 
            border: none; 
            border-radius: 8px; 
            font-weight: 700; 
            cursor: pointer; 
            transition: 0.3s; 
            font-size: 15px; 
            text-align: center; 
            text-decoration: none; 
            display: block; 
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .btn-primary { background: #ffa500; color: #000; margin-bottom: 15px; }
        .btn-primary:hover { background: #ffb733; transform: translateY(-2px); }
        
        .divider { display: flex; align-items: center; margin: 30px 0; }
        .divider span { background: #444; flex: 1; height: 1px; }
        .divider p { margin: 0 15px; color: #999; font-size: 14px; }
        
        .btn-google { 
            background: #fff; 
            color: #000; 
            border: none; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            gap: 10px; 
        }
        .btn-google:hover { background: #f0f0f0; transform: translateY(-2px); }
        
        .auth-footer { text-align: center; margin-top: 25px; font-size: 14px; color: #999; }
        .auth-footer a { color: #ffa500; text-decoration: none; font-weight: 600; }
        .auth-footer a:hover { text-decoration: underline; }
        
        .error-message { 
            background: rgba(220, 53, 69, 0.1); 
            color: #ff4d4d; 
            padding: 12px; 
            border-radius: 8px; 
            margin-bottom: 20px; 
            font-size: 14px; 
            border: 1px solid rgba(220, 53, 69, 0.2); 
            text-align: center;
        }
        
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #1e1e1e;
            border-top: 1px solid #333;
            display: none;
            justify-content: space-around;
            align-items: center;
            height: 70px;
            z-index: 1000;
        }

        @media (max-width: 768px) {
            .bottom-nav {
                display: flex;
            }
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            flex: 1;
            height: 100%;
            color: #999;
            text-decoration: none;
            font-size: 12px;
            transition: 0.3s;
            gap: 5px;
        }

        .nav-item:hover,
        .nav-item.active {
            color: #ffa500;
        }

        .nav-item i {
            font-size: 24px;
        }
        
        @media (max-width: 480px) {
            .auth-card { padding: 25px; }
            .auth-header h1 { font-size: 28px; }
        }
    </style>
</head>
<body>
    <nav class="bottom-nav">
        <a href="/" class="nav-item" title="Inicio">
            <i class="fas fa-home"></i>
            <span>Inicio</span>
        </a>
        <a href="/" class="nav-item" title="Busca">
            <i class="fas fa-search"></i>
            <span>Busca</span>
        </a>
        <a href="/outros" class="nav-item" title="Menu">
            <i class="fas fa-bars"></i>
            <span>Menu</span>
        </a>
        <a href="/auth/login" class="nav-item active" title="Entrar">
            <i class="fas fa-user"></i>
            <span>Entrar</span>
        </a>
    </nav>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <h1>Contrataê</h1>
                <p>Crie sua conta gratuitamente</p>
            </div>
            
            <% if (erro) { %>
                <div class="error-message"><%= erro %></div>
            <% } %>
            
            <form method="POST" action="/auth/cadastro">
                <div class="form-group">
                    <label>Nome Completo</label>
                    <input type="text" name="full_name" required placeholder="Seu nome">
                </div>
                
                <div class="form-group">
                    <label>E-mail</label>
                    <input type="email" name="email" required placeholder="seu@email.com">
                </div>
                
                <div class="form-group">
                    <label>Telefone</label>
                    <input type="tel" name="phone_number" class="mask-phone" inputmode="numeric" pattern="[0-9]*" placeholder="(00) 00000-0000">
                </div>
                
                <input type="hidden" name="user_type" value="<%= userType %>">
                <div class="form-group">
                    <label>Tipo de Conta</label>
                    <input type="text" value="<%= userType === 'professional' ? 'Profissional' : 'Cliente' %>" disabled style="background: #333; cursor: not-allowed;">
                    <p style="font-size: 12px; color: #999; margin-top: 5px;">Deseja mudar? <a href="/auth/cadastro" style="color: #ffa500;">Clique aqui</a></p>
                </div>
                
                <div class="form-group">
                    <label>Senha</label>
                    <div class="password-wrapper">
                        <input type="password" id="password-registro" name="password" required placeholder="Crie uma senha">
                        <i class="fas fa-eye toggle-password" onclick="togglePassword('password-registro')"></i>
                    </div>
                </div>
                
                <div class="form-group">
                    <label>Confirmar Senha</label>
                    <div class="password-wrapper">
                        <input type="password" id="password-confirm" name="password_confirm" required placeholder="Confirme a senha">
                        <i class="fas fa-eye toggle-password" onclick="togglePassword('password-confirm')"></i>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary">Criar Conta</button>
            </form>
            
            <div class="divider">
                <span></span>
                <p>ou</p>
                <span></span>
            </div>
            
            <a href="/auth/google?type=<%= userType %>" class="btn btn-google" id="google-signup-btn">
                <i class="fab fa-google"></i> Cadastrar com Google
            </a>
            
            <div class="auth-footer">
                <p>Já tem uma conta? <a href="/auth/login">Faça login</a></p>
            </div>
        </div>
    </div>
    
    <script>
        function togglePassword(id) {
            const input = document.getElementById(id);
            const icon = event.target;
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }
    </script>
</body>
</html>
