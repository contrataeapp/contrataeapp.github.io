<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Contrataê</title>
    <link rel="icon" href="data:,">
    <link rel="stylesheet" href="/css/style_laranja_preto.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body { background-color: #111 !important; color: #fff !important; }
        main { min-height: calc(100vh - 200px); background: #111 !important; display: flex; align-items: center; justify-content: center; padding: 40px 20px; }
        .auth-container { background: #1a1a1a; border: 1px solid #333; border-radius: 16px; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5); max-width: 450px; width: 100%; overflow: hidden; }
        .auth-header { background: #000; color: white; padding: 40px 20px; text-align: center; border-bottom: 2px solid #ffa500; }
        .auth-header h1 { font-size: 1.8rem; margin-bottom: 10px; color: #ffa500; }
        .auth-body { padding: 40px; }
        .form-group label { color: #fff !important; }
        .form-group input { background: #222 !important; border: 1px solid #444 !important; color: #fff !important; }
        .form-group input:focus { border-color: #ffa500 !important; }
        .btn-google { background: #fff !important; color: #1a1a1a !important; border: none !important; }
        .auth-footer { color: #bbb !important; border-top: 1px solid #333 !important; }
        .divider { color: #666 !important; }
        .divider::before, .divider::after { background: #333 !important; }
    </style>
</head>
<body class="dark-mode">
    <%- include('../partials/header') %>

    <main>
        <div class="auth-container">
            <div class="auth-header">
                <h1>Bem-vindo de Volta</h1>
                <p>Acesse sua conta Contrataê</p>
            </div>

            <div class="auth-body">
                <% if (typeof erro !== 'undefined' && erro) { %>
                    <div style="background: rgba(255,0,0,0.1); color: #ff4444; padding: 12px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #ff4444;">
                        <i class="fas fa-exclamation-circle"></i> <%= erro %>
                    </div>
                <% } %>

                <form method="POST" action="/auth/login" id="loginForm">
                    <div class="form-group" style="margin-bottom: 20px;">
                        <label style="display: block; margin-bottom: 8px;">E-mail</label>
                        <input type="email" name="email" required placeholder="seu@email.com" style="width: 100%; padding: 12px; border-radius: 8px;">
                    </div>

                    <div class="form-group" style="margin-bottom: 20px; position: relative;">
                        <label style="display: block; margin-bottom: 8px;">Senha</label>
                        <input type="password" id="password" name="password" required placeholder="••••••••" style="width: 100%; padding: 12px; border-radius: 8px;">
                    </div>

                    <button type="submit" style="width: 100%; padding: 14px; background: #ffa500; color: #000; border: none; border-radius: 8px; font-weight: bold; cursor: pointer;">
                        Entrar
                    </button>
                </form>

                <div class="divider" style="display: flex; align-items: center; margin: 30px 0;">
                    <span style="margin: 0 10px;">ou</span>
                </div>

                <a href="/auth/google" style="width: 100%; padding: 12px; background: white; color: #1a1a1a; border-radius: 8px; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 10px; text-decoration: none;">
                    <i class="fab fa-google"></i> Entrar com Google
                </a>

                <div class="auth-footer" style="text-align: center; padding-top: 20px; margin-top: 20px;">
                    Não tem conta? <a href="/auth/cadastro" style="color: #ffa500; font-weight: bold;">Cadastre-se aqui</a>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>
