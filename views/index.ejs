<!DOCTYPE html>
<html lang="pt-br">
<head>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QJ7GX28055"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QJ7GX28055');
    </script>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contrataê - Página Inicial</title>
    <link rel="icon" href="data:,">
    <link rel="stylesheet" href="/css/style_laranja_preto.css">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body>

    <% const bannerEsq = typeof banners !== 'undefined' && banners.find(b => b.position === 'category' && Number(b.order) >= 200 && Number(b.order) < 300); %>
    <% if (bannerEsq) { %>
    <div class="banner-lateral banner-esquerda" id="banner-mov">
        <button class="close-banner" title="Fechar anúncio">&times;</button>
        <div class="banner-content" data-link="<%= bannerEsq.link_destination || '#' %>">
            <img src="<%= bannerEsq.image_url %>" alt="<%= bannerEsq.title || 'Anúncio' %>">
        </div>
    </div>
    <% } %>

    <% const bannerDir = typeof banners !== 'undefined' && banners.find(b => b.position === 'category' && Number(b.order) >= 300); %>
    <% if (bannerDir) { %>
    <div class="banner-lateral banner-direita" id="banner-speed">
        <button class="close-banner" title="Fechar anúncio">&times;</button>
        <div class="banner-content" data-link="<%= bannerDir.link_destination || '#' %>">
            <img src="<%= bannerDir.image_url %>" alt="<%= bannerDir.title || 'Anúncio' %>">
        </div>
    </div>
    <% } %>

    <% if (!adminLogado && typeof userId !== 'undefined' && userId && userType === 'professional') { %>
    <div class="admin-top-bar" style="background: #ffa500; color: #000; padding: 10px 0; text-align: center; font-weight: bold;">
        <div class="container">
            <span><i class="fas fa-briefcase"></i> Modo Profissional Ativo</span>
            <a href="/profissional/dashboard" style="margin-left: 15px; background: #000; color: #fff; padding: 5px 15px; border-radius: 20px; text-decoration: none; font-size: 0.8rem;">Acessar Dashboard</a>
        </div>
    </div>
    <% } %>

    <% if (typeof adminLogado !== 'undefined' && adminLogado) { %>
    <div class="admin-top-bar" style="background: #ffa500; color: #000; padding: 10px 0; text-align: center; font-weight: bold;">
        <div class="container">
            <span><i class="fas fa-user-shield"></i> Modo Administrador Ativo</span>
            <a href="/admin" style="margin-left: 15px; background: #000; color: #fff; padding: 5px 15px; border-radius: 20px; text-decoration: none; font-size: 0.8rem;">Acessar Painel</a>
        </div>
    </div>
    <% } %>

    <%- include('partials/header', { currentPage: 'index' }) %>

    <main>
        <div class="container" style="text-align: center; margin-top: 20px;">
            <h1>Encontre o Profissional Ideal</h1>
            <p style="color: #ccc;">Rápido, fácil e seguro.</p>
        </div>

        <section class="carousel-section" id="carousel-topo">
            <div class="carousel-container">
                
                <% const bannersTopo = typeof banners !== 'undefined' ? banners.filter(b => b.position === 'home' && Number(b.order) < 100).sort((a,b)=>Number(a.order)-Number(b.order)) : []; %>
                
                <% if (bannersTopo.length > 0) { %>
                    <% bannersTopo.forEach(function(banner, index) { %>
                        <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                            <a href="#" class="trigger-modal" data-link="<%= banner.link_destination || '#' %>">
                                <img src="<%= banner.image_url %>" alt="<%= banner.title || 'Banner' %>" style="width:100%; height:100%;">
                            </a>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="carousel-item active">
                        <a href="#" class="trigger-modal" data-link="https://wa.me/5516996484492?text=Olá, vi o anúncio do Ponto Forte no Contrataê e gostaria de mais informações!">
                            <img src="/imagens/parceiros/ponto_forte.png" alt="Ponto Forte" style="width:100%; height:100%;">
                        </a>
                    </div>
                <% } %>

                <button class="carousel-btn prev-btn"><i class="fas fa-chevron-left"></i></button>
                <button class="carousel-btn next-btn"><i class="fas fa-chevron-right"></i></button>
                
                <div class="carousel-dots">
                    <% if (bannersTopo.length > 0) { %>
                        <% bannersTopo.forEach(function(_, index) { %>
                            <span class="dot <%= index === 0 ? 'active' : '' %>"></span>
                        <% }); %>
                    <% } else { %>
                        <span class="dot active"></span>
                    <% } %>
                </div>
            </div>
        </section>

        <section class="hero-section container" id="busca-rapida">
            <div class="search-box-wrapper">
                <input type="text" class="search-input" placeholder="O que você precisa? Ex: Pintor...">
                <button class="search-btn"><i class="fas fa-search"></i> Buscar</button>
            </div>
        </section>

        <section class="container content-section">
            <h2 class="section-title" style="text-align: center;">Serviços Mais Procurados</h2>
            <div class="service-cards">
                <a href="/categoria/pedreiros" class="card"><i class="fa-solid fa-trowel-bricks"></i><h4>Pedreiros</h4></a>
                <a href="/categoria/pintores" class="card"><i class="fas fa-paint-roller"></i><h4>Pintores</h4></a>
                <a href="/categoria/eletricistas" class="card"><i class="fas fa-bolt"></i><h4>Eletricistas</h4></a>
                <a href="/categoria/encanadores" class="card"><i class="fas fa-wrench"></i><h4>Encanadores</h4></a>
            </div>
            <div style="text-align: center; margin-top: 30px;">
                <a href="/categoria/outros" class="button secondary-button">Ver Todas as Categorias</a>
            </div>
        </section>

        <section class="container" style="margin-top: 50px; margin-bottom: 50px; text-align: center;">
            <h2 style="color: #ffa500; margin-bottom: 20px;">Como Funciona?</h2>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px;">
                <div style="background: #222; padding: 30px; border-radius: 12px; border: 1px solid #333;">
                    <i class="fas fa-search" style="font-size: 40px; color: #ffa500; margin-bottom: 15px;"></i>
                    <h3 style="color: #fff; margin-bottom: 10px;">1. Busque</h3>
                    <p style="color: #ccc; font-size: 14px;">Encontre profissionais qualificados em sua região para o serviço que você precisa.</p>
                </div>
                <div style="background: #222; padding: 30px; border-radius: 12px; border: 1px solid #333;">
                    <i class="fas fa-comments" style="font-size: 40px; color: #ffa500; margin-bottom: 15px;"></i>
                    <h3 style="color: #fff; margin-bottom: 10px;">2. Contate</h3>
                    <p style="color: #ccc; font-size: 14px;">Fale diretamente com o profissional e tire suas dúvidas sobre o serviço.</p>
                </div>
                <div style="background: #222; padding: 30px; border-radius: 12px; border: 1px solid #333;">
                    <i class="fas fa-check-double" style="font-size: 40px; color: #ffa500; margin-bottom: 15px;"></i>
                    <h3 style="color: #fff; margin-bottom: 10px;">3. Contrate</h3>
                    <p style="color: #ccc; font-size: 14px;">Combine os detalhes e realize o serviço com segurança e transparência.</p>
                </div>
            </div>
        </section>
    </main>

    <nav class="mobile-bottom-nav mobile-only">
        <a href="/" class="nav-item"><i class="fas fa-home"></i><span>Início</span></a>
        <a href="/#busca-rapida" class="nav-item"><i class="fas fa-search"></i><span>Busca</span></a>
        <button class="nav-item" id="mobile-menu-trigger"><i class="fas fa-bars"></i><span>Menu</span></button>
        <a href="/auth/login" class="nav-item"><i class="fas fa-user"></i><span>Entrar</span></a>
    </nav>

    <%- include('partials/footer') %>

    <script src="/js/search.js"></script>
</body>
</html>
