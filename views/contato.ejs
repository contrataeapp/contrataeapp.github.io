<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contato - Contrataê</title>
    <link rel="icon" href="data:,">
    <link rel="stylesheet" href="/css/style_laranja_preto.css">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        .contato-container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 20px;
        }

        .contato-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .contato-header h1 {
            font-size: 36px;
            color: #ffa500; /* Laranja oficial */
            margin-bottom: 10px;
        }

        .contato-header p {
            font-size: 16px;
            color: #ccc;
        }

        .contato-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-bottom: 50px;
        }

        .contato-info {
            background: #222; /* Fundo escuro */
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            border: 1px solid #333;
        }

        .contato-info h2 {
            color: #ffa500;
            margin-bottom: 25px;
            font-size: 22px;
            text-align: center;
        }

        .info-cards {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .info-card {
            background: #1a1a1a;
            padding: 20px;
            border-radius: 8px;
            text-align: center;
            transition: 0.3s;
            border: 1px solid #444;
        }

        .info-card:hover {
            transform: translateY(-5px);
            border-color: #ffa500;
        }

        .info-card i {
            font-size: 30px;
            color: #ffa500;
            margin-bottom: 15px;
        }

        .info-card h3 {
            color: #fff;
            font-size: 18px;
            margin-bottom: 10px;
        }

        .info-card p, .info-card a {
            color: #ccc;
            font-size: 14px;
            text-decoration: none;
        }

        .info-card a:hover {
            color: #ffa500;
        }

        .contato-form {
            background: #222;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            border: 1px solid #333;
        }

        .contato-form h2 {
            color: #ffa500;
            margin-bottom: 25px;
            font-size: 22px;
            text-align: center;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #fff;
            font-weight: 600;
            font-size: 14px;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #444;
            background: #1a1a1a;
            color: #fff;
            border-radius: 6px;
            font-size: 14px;
            font-family: inherit;
            transition: 0.3s;
            box-sizing: border-box;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #ffa500;
            box-shadow: 0 0 0 3px rgba(255, 165, 0, 0.1);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 120px;
        }

        .btn-submit {
            background: #ffa500;
            color: #000;
            padding: 12px 30px;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
            width: 100%;
        }

        .btn-submit:hover {
            background: #ff8c00;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 165, 0, 0.3);
        }

        .sobre-section {
            background: #222;
            padding: 40px;
            border-radius: 12px;
            margin-bottom: 50px;
            border: 1px solid #333;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }

        .sobre-section h2 {
            color: #ffa500;
            font-size: 28px;
            margin-bottom: 20px;
            text-align: center;
        }

        .sobre-section p {
            color: #ccc;
            font-size: 16px;
            line-height: 1.8;
            margin-bottom: 15px;
        }

        .sobre-section ul {
            color: #ccc;
            font-size: 16px;
            line-height: 1.8;
            margin-left: 20px;
        }

        .sobre-section li {
            margin-bottom: 10px;
        }

        .sobre-section strong {
            color: #ffa500;
        }

        @media (max-width: 768px) {
            .contato-grid {
                grid-template-columns: 1fr;
                gap: 30px;
            }

            .contato-header h1 {
                font-size: 28px;
            }

            .contato-container {
                margin: 20px auto;
            }
        }
    </style>
</head>
<body class="dark-mode">
    <% const bannerEsq = typeof banners !== 'undefined' && banners.find(b => b.posicao === 3); %>
    <% if (bannerEsq) { %>
    <div class="banner-lateral banner-esquerda" id="banner-mov">
        <button class="close-banner" title="Fechar anúncio">&times;</button>
        <div class="banner-content" data-link="<%= bannerEsq.link_destino || '#' %>">
            <img src="<%= bannerEsq.imagem_url %>" alt="<%= bannerEsq.titulo || 'Anúncio' %>">
        </div>
    </div>
    <% } %>

    <% const bannerDir = typeof banners !== 'undefined' && banners.find(b => b.posicao === 4); %>
    <% if (bannerDir) { %>
    <div class="banner-lateral banner-direita" id="banner-speed">
        <button class="close-banner" title="Fechar anúncio">&times;</button>
        <div class="banner-content" data-link="<%= bannerDir.link_destino || '#' %>">
            <img src="<%= bannerDir.imagem_url %>" alt="<%= bannerDir.titulo || 'Anúncio' %>">
        </div>
    </div>
    <% } %>

    <header class="airbnb-header">
        <div class="container header-grid">
            <div class="header-left">
                <a href="/" class="site-logo"><img src="/imagens/logo/logo_contratae.png" alt="Logo Contrataê"></a>
            </div>

            <div class="header-center desktop-only">
                <div class="search-pill">
                    <input type="text" class="search-input-pill" placeholder="Busque por pintor, pedreiro...">
                    <button class="search-btn-round"><i class="fas fa-search"></i></button>
                </div>
            </div>

            <div class="header-right">
                <div id="google_translate_element" class="desktop-only"></div>
                <button id="theme-toggle" class="icon-btn"><i class="fas fa-moon"></i></button>
                <a href="/auth/login" class="login-pill desktop-only">
                    <span class="login-text">Entrar / Cadastrar</span>
                    <span class="login-icon"><i class="fas fa-user-circle"></i></span>
                </a>
            </div>
        </div>

        <nav class="categories-nav" id="main-nav">
            <div class="container">
                <div class="nav-header mobile-only">
                    <h3>Menu</h3>
                    <button id="close-menu-btn"><i class="fas fa-times"></i></button>
                </div>
                <ul>
                    <li><a href="/"><i class="fas fa-home"></i> Início</a></li>
                    <li><a href="/pintores"><i class="fas fa-paint-roller"></i> Pintores</a></li>
                    <li><a href="/pedreiros"><i class="fa-solid fa-trowel-bricks"></i> Pedreiros</a></li>
                    <li><a href="/eletricistas"><i class="fas fa-bolt"></i> Eletricistas</a></li>
                    <li><a href="/encanadores"><i class="fas fa-wrench"></i> Encanadores</a></li>
                    <li><a href="/outros"><i class="fas fa-th"></i> Outros</a></li>
                    <li><a href="/contato" class="active"><i class="fas fa-envelope"></i> Contato</a></li>
                    <li class="mobile-only"><a href="/auth/login"><i class="fas fa-user"></i> Entrar / Cadastrar</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main>
        <div class="contato-container">
            <div class="contato-header">
                <h1>Entre em Contato</h1>
                <p>Tem dúvidas ou sugestões? Adoraríamos ouvir de você!</p>
            </div>

            <div class="sobre-section">
                <h2>Conheça a Contrataê</h2>
                <p>
                    Na <strong>Contrataê</strong>, nossa paixão é conectar pessoas que precisam de soluções com profissionais que as oferecem com excelência. Acreditamos que a tecnologia pode simplificar o dia a dia e trazer mais eficiência para a contratação de serviços.
                </p>
                <p>
                    Desde a nossa fundação, trabalhamos incansavelmente para construir uma plataforma intuitiva, segura e confiável, onde clientes encontram desde pequenos reparos até grandes projetos, e profissionais expandem suas oportunidades de trabalho.
                </p>
                <p>
                    Nosso compromisso é com a <strong>qualidade</strong>, a <strong>transparência</strong> e a <strong>inovação</strong>. Estamos sempre buscando novas maneiras de aprimorar a experiência de todos os usuários, garantindo que cada conexão seja um sucesso.
                </p>
                
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 30px;">
                    <div style="text-align: center;">
                        <i class="fas fa-bullseye" style="font-size: 30px; color: #ffa500; margin-bottom: 10px;"></i>
                        <h4 style="color: #fff;">Nossa Missão</h4>
                        <p style="font-size: 14px;">Conectar pessoas a profissionais de forma rápida, segura e eficiente.</p>
                    </div>
                    <div style="text-align: center;">
                        <i class="fas fa-eye" style="font-size: 30px; color: #ffa500; margin-bottom: 10px;"></i>
                        <h4 style="color: #fff;">Nossa Visão</h4>
                        <p style="font-size: 14px;">Ser a plataforma líder em agendamento de serviços no Brasil.</p>
                    </div>
                    <div style="text-align: center;">
                        <i class="fas fa-heart" style="font-size: 30px; color: #ffa500; margin-bottom: 10px;"></i>
                        <h4 style="color: #fff;">Nossos Valores</h4>
                        <p style="font-size: 14px;">Qualidade, Transparência, Inovação e Respeito.</p>
                    </div>
                </div>
            </div>

            <div class="contato-grid">
                <div class="contato-info">
                    <h2>Fale Conosco</h2>
                    
                    <div class="info-cards">
                        <div class="info-card">
                            <i class="fas fa-envelope"></i>
                            <h3>E-mail</h3>
                            <p><a href="mailto:time.contratae@gmail.com">time.contratae@gmail.com</a></p>
                        </div>

                        <div class="info-card">
                            <i class="fab fa-instagram"></i>
                            <h3>Instagram</h3>
                            <p><a href="#">@contratae</a></p>
                        </div>

                        <div class="info-card">
                            <i class="fab fa-facebook"></i>
                            <h3>Facebook</h3>
                            <p><a href="#">Contrataê</a></p>
                        </div>
                    </div>
                </div>

                <div class="contato-form">
                    <h2>Envie uma Mensagem Direta</h2>
                    <form method="POST" action="/api/contato" id="contact-form" onsubmit="handleContactSubmit(event)">
                        <div class="form-group">
                            <label for="nome">Seu Nome:</label>
                            <input type="text" id="nome" name="nome" required placeholder="Digite seu nome">
                        </div>

                        <div class="form-group">
                            <label for="email">Seu E-mail:</label>
                            <input type="email" id="email" name="email" required placeholder="seu@email.com">
                        </div>

                        <div class="form-group">
                            <label for="assunto">Assunto:</label>
                            <input type="text" id="assunto" name="assunto" required placeholder="Qual o assunto?">
                        </div>

                        <div class="form-group">
                            <label for="mensagem">Mensagem:</label>
                            <textarea id="mensagem" name="mensagem" required placeholder="Escreva sua mensagem aqui..."></textarea>
                        </div>

                        <button type="submit" class="btn-submit">Enviar Mensagem</button>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <footer class="footer-section">
        <div class="container">
            <div class="footer-content">
                <div class="footer-col">
                    <h4>Sobre Contrataê</h4>
                    <ul>
                        <li><a href="/contato">Contato</a></li>
                        <li><a href="/contato">Sobre Nós</a></li>
                        <li><a href="#">Blog</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Para Profissionais</h4>
                    <ul>
                        <li><a href="/auth/login">Cadastre-se</a></li>
                        <li><a href="#">Como Funciona</a></li>
                        <li><a href="#">Suporte</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Para Clientes</h4>
                    <ul>
                        <li><a href="/">Buscar Profissionais</a></li>
                        <li><a href="#">Segurança</a></li>
                        <li><a href="#">FAQ</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Redes Sociais</h4>
                    <ul>
                        <li><a href="#"><i class="fab fa-facebook"></i> Facebook</a></li>
                        <li><a href="#"><i class="fab fa-instagram"></i> Instagram</a></li>
                        <li><a href="https://wa.me/5516996484492"><i class="fab fa-whatsapp"></i> WhatsApp</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="footer-copyright-bar">
            <div class="container copyright-flex">
                <p>&copy; 2026 Contrataê</p>
                <div class="footer-links"><a href="#">Avaliação</a> | <a href="/contato">Sobre Nós</a> | <a href="#">Termos</a></div>
            </div>
        </div>
    </footer>

    <script type="text/javascript">
        function handleContactSubmit(event) {
            event.preventDefault();
            const form = event.target;
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);

            fetch('/api/contato', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(result => {
                if (result.sucesso) {
                    alert('Mensagem enviada com sucesso! Entraremos em contato em breve.');
                    form.reset();
                } else {
                    alert('Erro ao enviar mensagem: ' + (result.erro || 'Tente novamente'));
                }
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro ao enviar mensagem. Tente novamente.');
            });
        }

        function googleTranslateElementInit() {
          new google.translate.TranslateElement({
              pageLanguage: 'pt', 
              includedLanguages: 'pt,en', 
              layout: google.translate.TranslateElement.InlineLayout.SIMPLE
            }, 'google_translate_element');
        }
    </script>
    <script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    <script src="/js/theme-toggle.js"></script>
    <script src="/js/index.js"></script>
</body>
</html>
