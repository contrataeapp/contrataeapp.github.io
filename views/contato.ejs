<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contrataê - Contato</title>
    
    <link rel="stylesheet" href="/css/style_laranja_preto.css">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        .contact-hero {
            background: linear-gradient(135deg, #ffa500 0%, #ff8c00 100%);
            padding: 60px 20px;
            text-align: center;
            color: white;
            margin-bottom: 40px;
        }

        .contact-hero h1 {
            color: white;
            font-size: 2.5rem;
            margin-bottom: 15px;
        }

        .contact-hero p {
            font-size: 1.1rem;
            opacity: 0.95;
            margin: 0;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 50px;
        }

        .contact-card {
            background: #222;
            padding: 30px;
            border-radius: 12px;
            border: 1px solid #333;
            text-align: center;
            transition: all 0.3s ease;
        }

        .contact-card:hover {
            border-color: #ffa500;
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(255, 165, 0, 0.2);
        }

        .contact-card-icon {
            font-size: 3rem;
            color: #ffa500;
            margin-bottom: 20px;
        }

        .contact-card h3 {
            color: white;
            margin: 0 0 15px 0;
            font-size: 1.3rem;
        }

        .contact-card p {
            color: #ccc;
            margin: 10px 0;
            font-size: 0.95rem;
        }

        .contact-card .contact-detail {
            background: #1a1a1a;
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
            font-weight: 600;
            color: #ffa500;
        }

        .contact-card .button {
            width: 100%;
            margin-top: 15px;
        }

        .faq-section {
            background: #1a1a1a;
            padding: 40px 20px;
            margin-bottom: 40px;
            border-radius: 12px;
        }

        .faq-section h2 {
            color: #ffa500;
            text-align: center;
            margin-bottom: 30px;
        }

        .faq-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .faq-item {
            background: #222;
            padding: 20px;
            border-radius: 8px;
            border-left: 4px solid #ffa500;
        }

        .faq-item h4 {
            color: #ffa500;
            margin: 0 0 10px 0;
        }

        .faq-item p {
            color: #ccc;
            margin: 0;
            font-size: 0.95rem;
        }

        .social-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 30px;
            flex-wrap: wrap;
        }

        .social-links a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 50px;
            height: 50px;
            background: #ffa500;
            color: white;
            border-radius: 50%;
            transition: all 0.3s ease;
            font-size: 1.3rem;
        }

        .social-links a:hover {
            background: #ff8c00;
            transform: scale(1.1);
        }

        .form-section {
            background: #222;
            padding: 40px;
            border-radius: 12px;
            max-width: 600px;
            margin: 40px auto;
            border: 1px solid #333;
        }

        .form-section h3 {
            color: #ffa500;
            text-align: center;
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #ccc;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 6px;
            color: #fff;
            font-family: inherit;
            transition: all 0.3s ease;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #ffa500;
            box-shadow: 0 0 0 3px rgba(255, 165, 0, 0.1);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 120px;
        }

        .form-submit {
            width: 100%;
            padding: 14px;
            background: #ffa500;
            color: white;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .form-submit:hover {
            background: #ff8c00;
            transform: translateY(-2px);
        }

        @media (max-width: 768px) {
            .contact-hero h1 {
                font-size: 1.8rem;
            }

            .form-section {
                padding: 25px;
            }

            .contact-grid {
                gap: 20px;
            }
        }
    </style>
</head>
<body>

    <% const bannerEsq = typeof banners !== 'undefined' && banners.find(b => b.posicao === 3); %>
    <% if (bannerEsq) { %>
    <div class="banner-lateral banner-esquerda" id="banner-mov">
        <button class="close-banner" title="Fechar anúncio">&times;</button>
        <div class="banner-content" data-link="<%= bannerEsq.link_destino || '#' %>">
            <img src="<%= bannerEsq.imagem_url %>" alt="<%= bannerEsq.titulo || 'Anúncio' %>">
        </div>
    </div>
    <% } %>

    <% const bannerDir = typeof banners !== 'undefined' && banners.find(b => b.posicao === 4); %>
    <% if (bannerDir) { %>
    <div class="banner-lateral banner-direita" id="banner-speed">
        <button class="close-banner" title="Fechar anúncio">&times;</button>
        <div class="banner-content" data-link="<%= bannerDir.link_destino || '#' %>">
            <img src="<%= bannerDir.imagem_url %>" alt="<%= bannerDir.titulo || 'Anúncio' %>">
        </div>
    </div>
    <% } %>

    <%- include('partials/header') %>

    <main>
        <div class="contact-hero">
            <div class="container">
                <h1>Entre em Contato Conosco</h1>
                <p>Estamos aqui para ajudar! Fale conosco através de qualquer um dos canais abaixo.</p>
            </div>
        </div>

        <div class="container">
            <!-- CANAIS DE CONTATO -->
            <div class="contact-grid">
                <div class="contact-card">
                    <div class="contact-card-icon">
                        <i class="fab fa-whatsapp"></i>
                    </div>
                    <h3>WhatsApp</h3>
                    <p>Resposta rápida e direta</p>
                    <div class="contact-detail">(16) 99648-4492</div>
                    <p style="font-size: 0.85rem; color: #999;">Disponível de seg-sex, 8h às 18h</p>
                    <a href="https://wa.me/5516996484492?text=Olá! Gostaria de mais informações sobre o Contrataê." class="button primary-button" target="_blank">
                        <i class="fab fa-whatsapp"></i> Chamar no WhatsApp
                    </a>
                </div>

                <div class="contact-card">
                    <div class="contact-card-icon">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <h3>E-mail</h3>
                    <p>Mensagens detalhadas</p>
                    <div class="contact-detail">suporte@contrataeapp.com.br</div>
                    <p style="font-size: 0.85rem; color: #999;">Resposta em até 24 horas</p>
                    <a href="mailto:suporte@contrataeapp.com.br" class="button primary-button">
                        <i class="fas fa-envelope"></i> Enviar E-mail
                    </a>
                </div>

                <div class="contact-card">
                    <div class="contact-card-icon">
                        <i class="fas fa-phone"></i>
                    </div>
                    <h3>Telefone</h3>
                    <p>Conversa direta</p>
                    <div class="contact-detail">(16) 3201-5000</div>
                    <p style="font-size: 0.85rem; color: #999;">Seg-sex, 9h às 17h</p>
                    <a href="tel:+551632015000" class="button primary-button">
                        <i class="fas fa-phone"></i> Ligar Agora
                    </a>
                </div>
            </div>

            <!-- FORMULÁRIO DE CONTATO -->
            <div class="form-section">
                <h3><i class="fas fa-paper-plane"></i> Envie-nos uma Mensagem</h3>
                <form action="/api/contato" method="POST">
                    <div class="form-group">
                        <label for="nome">Nome Completo *</label>
                        <input type="text" id="nome" name="nome" required placeholder="Seu nome">
                    </div>

                    <div class="form-group">
                        <label for="email">E-mail *</label>
                        <input type="email" id="email" name="email" required placeholder="seu@email.com">
                    </div>

                    <div class="form-group">
                        <label for="telefone">Telefone</label>
                        <input type="tel" id="telefone" name="telefone" placeholder="(16) 99999-9999">
                    </div>

                    <div class="form-group">
                        <label for="assunto">Assunto *</label>
                        <input type="text" id="assunto" name="assunto" required placeholder="Qual é o seu assunto?">
                    </div>

                    <div class="form-group">
                        <label for="mensagem">Mensagem *</label>
                        <textarea id="mensagem" name="mensagem" required placeholder="Descreva sua dúvida ou sugestão..."></textarea>
                    </div>

                    <button type="submit" class="form-submit">
                        <i class="fas fa-paper-plane"></i> Enviar Mensagem
                    </button>
                </form>
            </div>

            <!-- FAQ -->
            <div class="faq-section">
                <h2>Perguntas Frequentes</h2>
                <div class="faq-grid">
                    <div class="faq-item">
                        <h4><i class="fas fa-question-circle"></i> Como funciona o Contrataê?</h4>
                        <p>O Contrataê é uma plataforma que conecta clientes com profissionais qualificados. Você busca o serviço desejado, encontra o profissional ideal e contrata com segurança.</p>
                    </div>

                    <div class="faq-item">
                        <h4><i class="fas fa-question-circle"></i> Qual é o custo?</h4>
                        <p>O Contrataê é gratuito para clientes. Os profissionais pagam uma taxa apenas quando realizam um serviço. Sem taxas ocultas!</p>
                    </div>

                    <div class="faq-item">
                        <h4><i class="fas fa-question-circle"></i> Como me cadastro?</h4>
                        <p>Clique em "Entrar / Cadastrar" no topo da página, escolha seu tipo de conta (cliente ou profissional) e preencha seus dados. Leva menos de 2 minutos!</p>
                    </div>

                    <div class="faq-item">
                        <h4><i class="fas fa-question-circle"></i> Como posso confiar nos profissionais?</h4>
                        <p>Todos os profissionais passam por verificação. Você pode ver avaliações, portfólio e comentários de clientes anteriores antes de contratar.</p>
                    </div>

                    <div class="faq-item">
                        <h4><i class="fas fa-question-circle"></i> Há garantia de segurança?</h4>
                        <p>Sim! Usamos criptografia de ponta a ponta, verificação de identidade e um sistema de avaliação transparente para garantir sua segurança.</p>
                    </div>

                    <div class="faq-item">
                        <h4><i class="fas fa-question-circle"></i> Posso cancelar um serviço contratado?</h4>
                        <p>Sim, você pode cancelar com até 24 horas de antecedência. Leia nossa política de cancelamento para mais detalhes.</p>
                    </div>
                </div>
            </div>

            <!-- REDES SOCIAIS -->
            <div style="text-align: center; margin: 50px 0; padding: 40px; background: #222; border-radius: 12px;">
                <h3 style="color: #ffa500; margin-bottom: 20px;">Siga-nos nas Redes Sociais</h3>
                <p style="color: #ccc; margin-bottom: 25px;">Fique por dentro das novidades e promoções do Contrataê</p>
                <div class="social-links">
                    <a href="https://instagram.com/contrataeapp" target="_blank" title="Instagram">
                        <i class="fab fa-instagram"></i>
                    </a>
                    <a href="https://facebook.com/contrataeapp" target="_blank" title="Facebook">
                        <i class="fab fa-facebook"></i>
                    </a>
                    <a href="https://linkedin.com/company/contrataeapp" target="_blank" title="LinkedIn">
                        <i class="fab fa-linkedin"></i>
                    </a>
                    <a href="https://twitter.com/contrataeapp" target="_blank" title="Twitter">
                        <i class="fab fa-twitter"></i>
                    </a>
                </div>
            </div>
        </div>
    </main>

    <nav class="mobile-bottom-nav mobile-only">
        <a href="/" class="nav-item"><i class="fas fa-home"></i><span>Início</span></a>
        <a href="/#busca-rapida" class="nav-item"><i class="fas fa-search"></i><span>Busca</span></a>
        <button class="nav-item" id="mobile-menu-trigger"><i class="fas fa-bars"></i><span>Menu</span></button>
        <a href="/auth/login" class="nav-item"><i class="fas fa-user"></i><span>Entrar</span></a>
    </nav>

    <%- include('partials/footer') %>

    <div id="external-link-modal" class="modal-overlay">
        <div class="modal-box">
            <h3>Você está saindo do Contrataê</h3>
            <p id="modal-msg">Você será redirecionado para um site externo.</p>
            <p class="modal-link-preview" id="modal-link-dest"></p>
            <div class="modal-buttons">
                <button id="cancel-link" class="button secondary-button">Cancelar</button>
                <button id="confirm-link" class="button primary-button">Continuar</button>
            </div>
        </div>
    </div>

    <script type="text/javascript">
        function googleTranslateElementInit() {
          new google.translate.TranslateElement({pageLanguage: 'pt', includedLanguages: 'pt,en', layout: google.translate.TranslateElement.InlineLayout.SIMPLE}, 'google_translate_element');
        }
    </script>
    <script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    <script src="/js/theme-toggle.js"></script>
    <script src="/js/search.js"></script>
    <script src="/js/index.js"></script>
    
    <div vw class="enabled">
        <div vw-access-button class="active"></div>
        <div vw-plugin-wrapper"><div class="vw-plugin-top-wrapper"></div></div>
    </div>
    <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>
    <script>new window.VLibras.Widget('https://vlibras.gov.br/app');</script>
</body>
</html>
