<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categoria - Contrataê</title>
    <link rel="icon" href="data:,">
    <link rel="stylesheet" href="/css/style_laranja_preto.css">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        .categoria-vazia-container {
            max-width: 800px;
            margin: 80px auto;
            padding: 40px 20px;
            text-align: center;
        }

        .empty-state {
            background: linear-gradient(135deg, #f8f9fa 0%, #f0f0f0 100%);
            border-radius: 16px;
            padding: 60px 40px;
            border: 2px dashed #ddd;
        }

        .empty-icon {
            font-size: 80px;
            color: #ffa500;
            margin-bottom: 20px;
            opacity: 0.8;
        }

        .empty-title {
            font-size: 28px;
            color: #1a1a1a;
            margin-bottom: 15px;
            font-weight: 600;
        }

        .empty-message {
            font-size: 16px;
            color: #666;
            line-height: 1.6;
            margin-bottom: 30px;
        }

        .empty-actions {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn {
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: #ffa500;
            color: white;
        }

        .btn-primary:hover {
            background: #ff8c00;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 165, 0, 0.3);
        }

        .btn-secondary {
            background: white;
            color: #1a1a1a;
            border: 2px solid #ffa500;
        }

        .btn-secondary:hover {
            background: #fffaf0;
            border-color: #ff8c00;
        }

        .info-box {
            background: #fffaf0;
            border-left: 4px solid #ffa500;
            padding: 20px;
            border-radius: 8px;
            margin-top: 40px;
            text-align: left;
        }

        .info-box h3 {
            color: #1a1a1a;
            margin-bottom: 10px;
            font-size: 16px;
        }

        .info-box p {
            color: #666;
            font-size: 14px;
            margin: 0;
            line-height: 1.6;
        }

        @media (max-width: 600px) {
            .categoria-vazia-container {
                margin: 60px auto;
                padding: 20px;
            }

            .empty-state {
                padding: 40px 20px;
            }

            .empty-icon {
                font-size: 60px;
            }

            .empty-title {
                font-size: 22px;
            }

            .empty-message {
                font-size: 14px;
            }

            .empty-actions {
                flex-direction: column;
            }

            .btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <% const bannerEsq = typeof banners !== 'undefined' && banners.find(b => b.posicao === 3); %>
    <% if (bannerEsq) { %>
    <div class="banner-lateral banner-esquerda" id="banner-mov">
        <button class="close-banner" title="Fechar anúncio">&times;</button>
        <div class="banner-content" data-link="<%= bannerEsq.link_destino || bannerEsq.link_destination || '#' %>">
            <img src="<%= bannerEsq.imagem_url || bannerEsq.image_url %>" alt="<%= bannerEsq.titulo || bannerEsq.title || 'Anúncio' %>">
        </div>
    </div>
    <% } %>

    <% const bannerDir = typeof banners !== 'undefined' && banners.find(b => b.posicao === 4); %>
    <% if (bannerDir) { %>
    <div class="banner-lateral banner-direita" id="banner-speed">
        <button class="close-banner" title="Fechar anúncio">&times;</button>
        <div class="banner-content" data-link="<%= bannerDir.link_destino || bannerDir.link_destination || '#' %>">
            <img src="<%= bannerDir.imagem_url || bannerDir.image_url %>" alt="<%= bannerDir.titulo || bannerDir.title || 'Anúncio' %>">
        </div>
    </div>
    <% } %>

    <%- include('partials/header') %>

    <main>
        <div class="categoria-vazia-container">
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-inbox"></i>
                </div>
                <h1 class="empty-title">Nenhum Profissional Encontrado</h1>
                <p class="empty-message">
                    Desculpe, no momento não temos profissionais cadastrados nesta categoria. 
                    <br>Mas não se preocupe! Novos profissionais estão se juntando à plataforma todos os dias.
                </p>

                <div class="empty-actions">
                    <a href="/" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Voltar ao Início
                    </a>
                    <a href="/outros" class="btn btn-secondary">
                        <i class="fas fa-th"></i> Ver Outras Categorias
                    </a>
                    <a href="/auth/login" class="btn btn-primary">
                        <i class="fas fa-user-plus"></i> Cadastre-se como Profissional
                    </a>
                </div>

                <div class="info-box">
                    <h3><i class="fas fa-lightbulb" style="color: #ffa500; margin-right: 8px;"></i>Quer oferecer seus serviços?</h3>
                    <p>
                        Se você é um profissional nesta área, cadastre-se na plataforma Contrataê e comece a receber clientes! 
                        É rápido, fácil e seguro.
                    </p>
                </div>
            </div>
        </div>
    </main>

    <nav class="mobile-bottom-nav mobile-only">
        <a href="/" class="nav-item"><i class="fas fa-home"></i><span>Início</span></a>
        <a href="/#busca-rapida" class="nav-item"><i class="fas fa-search"></i><span>Busca</span></a>
        <button class="nav-item" id="mobile-menu-trigger"><i class="fas fa-bars"></i><span>Menu</span></button>
        <a href="/auth/login" class="nav-item"><i class="fas fa-user"></i><span>Entrar</span></a>
    </nav>

    <%- include('partials/footer') %>

    <script type="text/javascript">
        function googleTranslateElementInit() {
          new google.translate.TranslateElement({
              pageLanguage: 'pt', 
              includedLanguages: 'pt,en', 
              layout: google.translate.TranslateElement.InlineLayout.SIMPLE
            }, 'google_translate_element');
        }
    </script>
    <script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    <script src="/js/theme-toggle.js"></script>
    <script src="/js/index.js"></script>
</body>
</html>
