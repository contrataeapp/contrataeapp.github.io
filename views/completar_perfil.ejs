<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include('partials/head', { title: 'Completar Perfil Profissional' }) %>
    <link rel="stylesheet" href="/css/style_laranja_preto.css">
    <link rel="stylesheet" href="/css/index.css">
</head>
<body class="dark-mode">
    <%- include('partials/header') %>

    <main style="min-height: 80vh; padding: 40px 20px;">
        <div class="container" style="max-width: 800px; background: #222; padding: 30px; border-radius: 15px; border: 1px solid #333;">
            <h1 style="color: #ffa500; margin-bottom: 10px;">Complete seu Perfil Profissional</h1>
            <p style="color: #ccc; margin-bottom: 30px;">Para aparecer nas buscas, precisamos de algumas informações sobre seu trabalho.</p>

            <% if (typeof erro !== 'undefined' && erro) { %>
                <div style="background: rgba(255, 0, 0, 0.1); color: #ff4444; padding: 12px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #ff4444;">
                    <%= erro %>
                </div>
            <% } %>

            <form action="/profissional/completar-perfil" method="POST" class="auth-form">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group">
                        <label for="nome">Nome Completo ou Fantasia</label>
                        <input type="text" id="nome" name="nome" value="<%= profissional.nome || user.full_name %>" required>
                    </div>
                    <div class="form-group">
                        <label for="profissao">Sua Profissão</label>
                        <input type="text" id="profissao" name="profissao" value="<%= profissional.profissao || '' %>" placeholder="Ex: Eletricista, Pintor, Diarista..." required>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px;">
                    <div class="form-group">
                        <label for="telefone">WhatsApp para Contato</label>
                        <input type="text" id="telefone" name="telefone" value="<%= profissional.telefone || '' %>" placeholder="(00) 00000-0000" required>
                    </div>
                    <div class="form-group">
                        <label for="cidade">Cidade / Região de Atendimento</label>
                        <input type="text" id="cidade" name="cidade" value="<%= profissional.cidade || '' %>" placeholder="Ex: São Paulo - SP" required>
                    </div>
                </div>

                <div class="form-group" style="margin-top: 20px;">
                    <label for="descricao">Descrição do seu Trabalho</label>
                    <textarea id="descricao" name="descricao" rows="5" style="width: 100%; background: #333; border: 1px solid #444; color: #fff; border-radius: 8px; padding: 10px;" required><%= profissional.descricao || '' %></textarea>
                </div>

                <div class="form-group" style="margin-top: 20px; max-width: 300px;">
                    <label for="preco_medio">Preço Médio da Visita/Serviço (R$)</label>
                    <input type="number" id="preco_medio" name="preco_medio" step="0.01" value="<%= profissional.preco_medio || '' %>" placeholder="0,00" required>
                </div>

                <div style="margin-top: 40px; text-align: center;">
                    <button type="submit" class="button primary-button" style="width: 100%; max-width: 400px;">Enviar para Aprovação</button>
                    <p style="color: #888; font-size: 0.8rem; margin-top: 15px;">Seu perfil será analisado por nossa equipe e ficará ativo em breve.</p>
                </div>
            </form>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
