<header class="airbnb-header">
    <div class="container header-grid">
        <div class="header-left">
            <a href="/" class="site-logo"><img src="/imagens/logo/logo_contratae.png" alt="Logo Contrataê"></a>
        </div>

        <div class="header-center desktop-only">
            <div class="search-pill">
                <input type="text" class="search-input-pill" placeholder="Busque por pintor, pedreiro...">
                <button class="search-btn-round"><i class="fas fa-search"></i></button>
            </div>
        </div>

        <div class="header-right">
            <div id="google_translate_element" class="desktop-only"></div>
            
            <button id="theme-toggle" class="icon-btn" title="Alternar Tema">
                <i class="fas fa-moon"></i>
            </button>
            
            <% if (typeof adminLogado !== 'undefined' && adminLogado) { %>
                <a href="/admin" class="login-pill">
                    <span class="login-text">Painel ADM</span>
                    <span class="login-icon"><i class="fas fa-user-shield"></i></span>
                </a>
            <% } else if (typeof user !== 'undefined' && user) { %>
                <div class="user-dropdown" style="position: relative; display: inline-block;">
                    <button class="login-pill dropdown-trigger" style="display: flex; align-items: center; gap: 10px; background: #222; border: 1px solid #333; padding: 5px 15px; border-radius: 20px; cursor: pointer; color: #fff;">
                        <span class="login-text"><%= user.full_name.split(' ')[0] %></span>
                        <span class="login-icon">
                            <% if (user.avatar_url) { %>
                                <img src="<%= user.avatar_url %>" alt="Avatar" style="width: 24px; height: 24px; border-radius: 50%;">
                            <% } else { %>
                                <div style="width: 24px; height: 24px; border-radius: 50%; background: #ffa500; color: #000; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.8rem;">
                                    <%= user.full_name.charAt(0).toUpperCase() %>
                                </div>
                            <% } %>
                        </span>
                    </button>
                    <div class="dropdown-content" style="display: none; position: absolute; right: 0; background: #222; min-width: 160px; box-shadow: 0 8px 16px rgba(0,0,0,0.2); z-index: 1000; border-radius: 8px; border: 1px solid #333; margin-top: 5px;">
                        <a href="/<%= user.user_type %>-dashboard" style="color: #fff; padding: 12px 16px; text-decoration: none; display: block; font-size: 0.9rem;"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                        <hr style="border: 0; border-top: 1px solid #333; margin: 0;">
                        <a href="/auth/logout" style="color: #ff4444; padding: 12px 16px; text-decoration: none; display: block; font-size: 0.9rem;"><i class="fas fa-sign-out-alt"></i> Sair</a>
                    </div>
                </div>
                <script>
                    document.querySelector('.dropdown-trigger').addEventListener('click', function(e) {
                        e.stopPropagation();
                        const content = document.querySelector('.dropdown-content');
                        content.style.display = content.style.display === 'block' ? 'none' : 'block';
                    });
                    document.addEventListener('click', function() {
                        document.querySelector('.dropdown-content').style.display = 'none';
                    });
                </script>
            <% } else { %>
                <a href="/auth/login" class="login-pill">
                    <span class="login-text">Entrar / Cadastrar</span>
                    <span class="login-icon"><i class="fas fa-user-circle"></i></span>
                </a>
            <% } %>
        </div>
    </div>

    <nav class="categories-nav" id="main-nav">
        <div class="container">
            <div class="nav-header mobile-only">
                <h3>Menu</h3>
                <button id="close-menu-btn"><i class="fas fa-times"></i></button>
            </div>
            <ul>
                <li><a href="/" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'index') ? 'active' : '' %>"><i class="fas fa-home"></i> Início</a></li>
                <li><a href="/categoria/pintores" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'pintores') ? 'active' : '' %>"><i class="fas fa-paint-roller"></i> Pintores</a></li>
                <li><a href="/categoria/pedreiros" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'pedreiros') ? 'active' : '' %>"><i class="fa-solid fa-trowel-bricks"></i> Pedreiros</a></li>
                <li><a href="/categoria/eletricistas" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'eletricistas') ? 'active' : '' %>"><i class="fas fa-bolt"></i> Eletricistas</a></li>
                <li><a href="/categoria/encanadores" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'encanadores') ? 'active' : '' %>"><i class="fas fa-wrench"></i> Encanadores</a></li>
                <li><a href="/outros" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'outros') ? 'active' : '' %>"><i class="fas fa-th"></i> Outros</a></li>
                <li><a href="/contato" class="<%= (typeof currentPage !== 'undefined' && currentPage === 'contato') ? 'active' : '' %>"><i class="fas fa-envelope"></i> Contato</a></li>
                <% if (typeof user === 'undefined' || !user) { %>
                    <li class="mobile-only"><a href="/auth/login"><i class="fas fa-user"></i> Entrar / Cadastrar</a></li>
                <% } %>
            </ul>
        </div>
    </nav>
</header>
