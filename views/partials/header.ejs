<% 
    const current = typeof currentPage !== 'undefined' ? currentPage : ''; 
%>
<header>
    <div class="container" style="display: flex; justify-content: space-between; align-items: center; padding: 15px 20px;">
        <div class="site-logo">
            <a href="/"><img src="/imagens/logo/logo_contratae.png" alt="Contrataê" style="height: 50px;"></a>
        </div>
        
        <div style="display: flex; align-items: center; gap: 15px;">
            <div id="google_translate_element"></div>
            <button id="theme-toggle" class="button secondary-button" style="padding: 8px 12px;"><i class="fas fa-moon"></i></button>
            <a href="/auth/login" class="button primary-button">Entrar</a>
        </div>
    </div>

    <nav class="main-nav">
        <div class="container">
            <ul>
                <li><a href="/" class="<%= current === 'index' ? 'active' : '' %>"><i class="fas fa-home"></i> Início</a></li>
                <li><a href="/pintores" class="<%= current === 'pintores' ? 'active' : '' %>"><i class="fas fa-paint-roller"></i> Pintores</a></li>
                <li><a href="/pedreiros" class="<%= current === 'pedreiros' ? 'active' : '' %>"><i class="fa-solid fa-trowel-bricks"></i> Pedreiros</a></li>
                <li><a href="/eletricistas" class="<%= current === 'eletricistas' ? 'active' : '' %>"><i class="fas fa-bolt"></i> Eletricistas</a></li>
                <li><a href="/encanadores" class="<%= current === 'encanadores' ? 'active' : '' %>"><i class="fas fa-wrench"></i> Encanadores</a></li>
                <li><a href="/outros" class="<%= current === 'outros' ? 'active' : '' %>"><i class="fas fa-th"></i> Outros</a></li>
                <li><a href="/contato" class="<%= current === 'contato' ? 'active' : '' %>"><i class="fas fa-envelope"></i> Contato</a></li>
                <% if (typeof adminLogado !== 'undefined' && adminLogado) { %>
                    <li><a href="/admin" class="<%= current === 'admin' ? 'active' : '' %>"><i class="fas fa-user-shield"></i> Admin</a></li>
                <% } %>
            </ul>
        </div>
    </nav>
</header>

<script>
    // Script simples para o theme toggle se não existir
    const btn = document.getElementById('theme-toggle');
    if (btn) {
        btn.addEventListener('click', () => {
            document.body.classList.toggle('light-mode');
            const icon = btn.querySelector('i');
            if (document.body.classList.contains('light-mode')) {
                icon.classList.replace('fa-moon', 'fa-sun');
            } else {
                icon.classList.replace('fa-sun', 'fa-moon');
            }
        });
    }
</script>
