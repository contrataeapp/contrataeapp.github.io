<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Outras Categorias - Contrataê</title>
    <link rel="icon" href="data:,">
    <link rel="stylesheet" href="/css/style_laranja_preto.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body { background-color: #111 !important; color: #fff !important; }
        main { min-height: calc(100vh - 200px); background: #111 !important; padding: 40px 20px; }
        .hero-section { background: #1a1a1a; color: white; padding: 40px 20px; text-align: center; border-bottom: 4px solid #ffa500; margin-bottom: 40px; }
        .categories-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; max-width: 1200px; margin: 0 auto; }
        .category-card { background: #1a1a1a; border: 1px solid #333; border-radius: 15px; padding: 30px; text-align: center; transition: 0.3s; cursor: pointer; text-decoration: none; display: flex; flex-direction: column; align-items: center; justify-content: center; }
        .category-card:hover { border-color: #ffa500; transform: translateY(-5px); background: #222; }
        .category-card i { font-size: 3rem; color: #ffa500; margin-bottom: 15px; }
        .category-card h3 { color: #fff; font-size: 1.2rem; margin: 0; }
        .category-phrase { font-size: 0.9rem; color: #bbb; margin-top: 10px; }
    </style>
</head>
<body class="dark-mode">
    <%- include('partials/header') %>

    <main>
        <section class="hero-section">
            <div class="container">
                <h1>Todas as Categorias</h1>
                <p>Explore todas as profissões disponíveis na Contrataê</p>
            </div>
        </section>

        <div class="container">
            <div class="categories-grid">
                <% if (typeof categorias !== 'undefined' && categorias.length > 0) { %>
                    <% categorias.forEach(function(cat) { %>
                        <a href="/categoria/<%= cat.slug %>" class="category-card">
                            <i class="fas <%= cat.icon_url || 'fa-tools' %>"></i>
                            <h3><%= cat.name %></h3>
                            <p class="category-phrase"><%= cat.generic_phrase || 'Encontre profissionais' %></p>
                        </a>
                    <% }); %>
                <% } else { %>
                    <div style="grid-column: 1/-1; text-align: center; padding: 40px;">
                        <p style="color: #ccc;">Nenhuma categoria adicional encontrada no momento.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
