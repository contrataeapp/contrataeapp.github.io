<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= categoriaNome %> - Contrataê</title>
    <link rel="stylesheet" href="/css/style_laranja_preto.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body>
    <%- include('partials/top-status-bar') %>
    <%- include('partials/header', { currentPage: currentPage }) %>

    <main class="container" style="margin-top: 30px; margin-bottom: 50px;">
        <div style="text-align: center; margin-bottom: 40px;">
            <h1 style="color: #ffa500;"><%= categoriaNome %>s Disponíveis</h1>
            <p style="color: #ccc;">Encontre os melhores profissionais para suas necessidades.</p>
        </div>

        <% if (profissionais && profissionais.length > 0) { %>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 25px;">
                <% profissionais.forEach((prof) => { %>
                    <div style="background: #222; border-radius: 12px; overflow: hidden; border: 1px solid #333; transition: 0.3s;">
                        <div style="height: 200px; overflow: hidden; position: relative;">
                            <img src="<%= prof.users?.avatar_url || '/imagens/default-avatar.png' %>" alt="<%= prof.users?.full_name %>" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <div style="padding: 20px;">
                            <h3 style="color: #fff; margin-bottom: 5px;"><%= prof.users?.full_name %></h3>
                            <p style="color: #ffa500; font-size: 0.9rem; margin-bottom: 15px;"><%= categoriaNome %></p>
                            <p style="color: #ccc; font-size: 0.85rem; margin-bottom: 20px; height: 40px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                <%= prof.description || 'Profissional qualificado pronto para atender suas necessidades.' %>
                            </p>
                            
                            <div style="display: flex; gap: 10px;">
                                <a href="/perfil/<%= prof.id %>" style="flex: 1; background: #ffa500; color: #000; text-align: center; padding: 10px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 0.9rem;">Ver Perfil</a>
                                <a href="https://wa.me/<%= prof.users?.phone_number %>" target="_blank" style="background: #25d366; color: #fff; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 8px; text-decoration: none;"><i class="fab fa-whatsapp"></i></a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div style="text-align: center; padding: 50px; background: #222; border-radius: 12px; border: 1px solid #333;">
                <i class="fas fa-search" style="font-size: 50px; color: #444; margin-bottom: 20px;"></i>
                <h3 style="color: #fff;">Nenhum profissional encontrado</h3>
                <p style="color: #ccc;">No momento não temos profissionais ativos nesta categoria.</p>
                <a href="/" style="display: inline-block; margin-top: 20px; color: #ffa500; text-decoration: none;">Voltar para o início</a>
            </div>
        <% } %>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
