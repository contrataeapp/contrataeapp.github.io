<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= profissional.nome %> - Contrataê</title>
    <link rel="stylesheet" href="/css/style_laranja_preto.css">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        .perfil-container {
            max-width: 1120px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .perfil-header {
            margin-bottom: 24px;
        }

        .perfil-header h1 {
            font-size: 26px;
            color: #fff;
            margin-bottom: 8px;
        }

        .perfil-meta {
            display: flex;
            gap: 16px;
            color: #ccc;
            font-size: 14px;
        }

        .perfil-meta span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .perfil-meta .rating {
            color: #ffa500;
            font-weight: bold;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            grid-template-rows: 200px 200px;
            gap: 8px;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 32px;
        }

        .gallery-item {
            width: 100%;
            height: 100%;
            object-fit: cover;
            cursor: pointer;
            transition: 0.3s;
        }

        .gallery-item:hover {
            filter: brightness(0.8);
        }

        .main-img {
            grid-row: span 2;
        }

        .perfil-content {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 80px;
        }

        .info-section h2 {
            font-size: 22px;
            color: #fff;
            margin-bottom: 24px;
            padding-bottom: 24px;
            border-bottom: 1px solid #333;
        }

        .description {
            color: #ccc;
            line-height: 1.6;
            margin-bottom: 32px;
        }

        .features-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 32px;
        }

        .feature-item {
            display: flex;
            gap: 16px;
            align-items: flex-start;
        }

        .feature-item i {
            font-size: 24px;
            color: #ffa500;
        }

        .feature-text h4 {
            color: #fff;
            margin-bottom: 4px;
        }

        .feature-text p {
            color: #ccc;
            font-size: 14px;
        }

        .booking-card {
            background: #222;
            border: 1px solid #333;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 6px 16px rgba(0,0,0,0.3);
            position: sticky;
            top: 100px;
        }

        .price-info {
            font-size: 22px;
            color: #fff;
            margin-bottom: 24px;
        }

        .price-info span {
            font-size: 16px;
            color: #ccc;
            font-weight: normal;
        }

        .btn-contact {
            background: #ffa500;
            color: #000;
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-decoration: none;
        }

        .btn-contact:hover {
            background: #ff8c00;
            transform: translateY(-2px);
        }

        @media (max-width: 768px) {
            .gallery-grid {
                grid-template-columns: 1fr;
                grid-template-rows: 300px;
            }
            .gallery-item:not(.main-img) {
                display: none;
            }
            .perfil-content {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            .booking-card {
                position: static;
            }
        }
    </style>
</head>
<body class="dark-mode">
    <%- include('partials/header') %>

    <main class="perfil-container">
        <div class="perfil-header">
            <h1><%= profissional.nome %> - <%= profissional.profissao %></h1>
            <div class="perfil-meta">
                <span class="rating"><i class="fas fa-star"></i> 4.9 (12 avaliações)</span>
                <span><i class="fas fa-map-marker-alt"></i> <%= profissional.cidade || 'Taquaritinga' %>, SP</span>
            </div>
        </div>

        <div class="gallery-grid">
            <img src="<%= profissional.foto_url || '/imagens/profissionais/default.png' %>" class="gallery-item main-img" alt="Foto Principal">
            <img src="/imagens/trabalhos/trabalho1.jpg" class="gallery-item" alt="Trabalho 1">
            <img src="/imagens/trabalhos/trabalho2.jpg" class="gallery-item" alt="Trabalho 2">
            <img src="/imagens/trabalhos/trabalho3.jpg" class="gallery-item" alt="Trabalho 3">
            <img src="/imagens/trabalhos/trabalho4.jpg" class="gallery-item" alt="Trabalho 4">
        </div>

        <div class="perfil-content">
            <div class="info-section">
                <h2>Sobre o Profissional</h2>
                <div class="description">
                    <p><%= profissional.descricao || 'Profissional qualificado pronto para atender suas necessidades com excelência e pontualidade.' %></p>
                </div>

                <div class="features-grid">
                    <div class="feature-item">
                        <i class="fas fa-check-circle"></i>
                        <div class="feature-text">
                            <h4>Verificado</h4>
                            <p>Identidade e documentos validados pela plataforma.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-tools"></i>
                        <div class="feature-text">
                            <h4>Equipamento Próprio</h4>
                            <p>O profissional possui todas as ferramentas necessárias.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="booking-sidebar">
                <div class="booking-card">
                    <div class="price-info">
                        A partir de R$ <%= profissional.preco || '80' %> <span>/ serviço</span>
                    </div>
                    <a href="https://wa.me/<%= profissional.whatsapp || '5516996484492' %>" class="btn-contact" target="_blank">
                        <i class="fab fa-whatsapp"></i> Contratar Agora
                    </a>
                    <p style="text-align: center; color: #ccc; font-size: 12px; margin-top: 16px;">
                        Você não será cobrado agora.
                    </p>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
