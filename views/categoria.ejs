<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contrataê - <%= categoriaNome %></title>
    <link rel="stylesheet" href="/css/style_laranja_preto.css">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body>
    <%- include('partials/header') %>

    <main>
        <div class="container" style="margin-top: 10px; margin-bottom: 40px;">
            <h2 class="section-title" style="text-align: center;"><%= categoriaNome %> Disponíveis</h2>
            
            <div class="professionals-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-top: 30px;">
                <% if (profissionais.length === 0) { %>
                    <div style="text-align: center; width: 100%; padding: 40px; color: #ccc; grid-column: 1 / -1;">
                        <i class="fas fa-user-slash" style="font-size: 3rem; margin-bottom: 15px; color: #555;"></i>
                        <h3>Nenhum profissional encontrado nesta categoria.</h3>
                        <p>Tente novamente mais tarde.</p>
                        <a href="/" class="button secondary-button" style="margin-top: 20px;">Voltar ao Início</a>
                    </div>
                <% } else { %>
                    <% profissionais.forEach(function(p) { %>
                        <div class="professional-card" style="background: #222; border-radius: 12px; overflow: hidden; border: 1px solid #333; transition: 0.3s;">
                            <div class="card-header-img" style="height: 200px; overflow: hidden;">
                                <img src="<%= p.photo_url || '/imagens/equipe_site/Mascote.png' %>" alt="<%= p.users.full_name %>" style="width: 100%; height: 100%; object-fit: cover;">
                            </div>
                            <div class="card-body" style="padding: 20px; text-align: center;">
                                <h3 style="color: #fff; margin-bottom: 5px;"><%= p.users.full_name %></h3>
                                <p class="profissao-tag" style="color: #ffa500; font-weight: bold; font-size: 0.9rem; margin-bottom: 10px;"><%= categoriaNome %></p>
                                <div class="rating" style="color: gold; margin-bottom: 15px;">
                                    <i class="fas fa-star"></i> 5.0
                                </div>
                                <div class="card-actions" style="display: flex; gap: 10px; justify-content: center;">
                                    <a href="https://wa.me/<%= p.users.phone_number ? p.users.phone_number.replace(/\D/g, '') : '5516996484492' %>?text=Olá, vi seu perfil no Contrataê e gostaria de fazer um orçamento." 
                                       class="button primary-button" style="background: #25d366; color: #fff; padding: 8px 15px; border-radius: 20px; text-decoration: none; font-size: 0.9rem;">
                                            <i class="fab fa-whatsapp"></i> Contatar
                                    </a>
                                    <a href="/perfil/<%= p.id %>" class="button secondary-button" style="background: #444; color: #fff; padding: 8px 15px; border-radius: 20px; text-decoration: none; font-size: 0.9rem;">Ver Perfil</a>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
    
    <script src="/js/theme-toggle.js"></script>
    <script src="/js/index.js"></script>
</body>
</html>
