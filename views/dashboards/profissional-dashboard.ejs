<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contrataê - Dashboard do Profissional</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:Inter,Arial,sans-serif;background:#0f0f10;color:#f5f5f5}
        .dashboard-container{display:flex;min-height:100vh}
        .sidebar{width:230px;background:#111;padding:24px 12px;position:fixed;inset:0 auto 0 0;border-right:1px solid #232323}
        .logo{font-size:22px;font-weight:800;margin-bottom:28px;text-align:center}.logo a{color:#ffb020;text-decoration:none}
        .sidebar ul{list-style:none}.sidebar li{margin-bottom:8px}
        .sidebar a{display:flex;align-items:center;gap:12px;color:#b8c0cc;text-decoration:none;padding:12px 14px;border-radius:12px;transition:.2s}
        .sidebar a:hover,.sidebar a.active{background:rgba(255,176,32,.12);color:#ffb020}
        .main{margin-left:230px;width:calc(100% - 230px);padding:28px}
        header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px} h1{color:#ffb020;font-size:24px}
        .user-chip{display:flex;align-items:center;gap:12px}.avatar{width:42px;height:42px;border-radius:50%;background:#ffb020;color:#111;font-weight:700;display:flex;align-items:center;justify-content:center;overflow:hidden}.avatar img{width:100%;height:100%;object-fit:cover}
        .tab-content{display:none}.tab-content.active{display:block}
        .cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px}.card,.panel{background:linear-gradient(180deg,#171717,#141414);border:1px solid #252525;border-radius:18px;padding:18px}
        .metric .icon{color:#ffb020;font-size:30px;margin-bottom:10px}.metric h3{color:#c2c9d1;font-size:13px;margin-bottom:8px}.metric .value{color:#ffb020;font-size:26px;font-weight:800}
        .banner{padding:18px 20px;border-radius:16px;border:1px solid #67491a;background:#2b1f0c;margin-bottom:20px}.banner h3{color:#ffb020;margin-bottom:6px;font-size:15px}.banner p{color:#f2e7d3;line-height:1.55}
        .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border:none;border-radius:12px;padding:11px 16px;font-weight:700;cursor:pointer;text-decoration:none}
        .btn-primary{background:#ffb020;color:#111}.btn-secondary{background:#24262b;color:#fff;border:1px solid #393c44}.btn-danger{background:#ad3030;color:#fff}
        .top-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}
        .small{color:#a9b0ba;font-size:13px}.flash{padding:14px 16px;border-radius:12px;margin-bottom:18px;border:1px solid #444}.flash.success{background:#142513;border-color:#285c27;color:#b9efb7}.flash.error{background:#291717;border-color:#6e2d2d;color:#ffb5b5}
        .summary-grid{display:grid;grid-template-columns:2fr 1fr;gap:16px}.detail-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.detail{padding:14px;border-radius:14px;border:1px solid #2a2d33;background:rgba(255,255,255,.02)}.detail strong{display:block;color:#ffb020;font-size:12px;margin-bottom:6px}
        .chip-wrap{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}.chip{padding:8px 12px;border-radius:999px;background:#181a1f;border:1px solid #2c3037;color:#dde3ea;font-size:13px}
        .portfolio-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-top:14px}.portfolio-thumb{position:relative;border:1px solid #2c3037;border-radius:14px;overflow:hidden;background:#121316;min-height:140px;display:flex;align-items:center;justify-content:center}.portfolio-thumb img{width:100%;height:140px;object-fit:cover}
        .table-wrap{overflow:auto} table{width:100%;border-collapse:collapse} th,td{padding:12px;border-bottom:1px solid #282b31;text-align:left} th{color:#a8b0ba;font-size:12px;text-transform:uppercase}
        .badge{padding:6px 10px;border-radius:999px;font-size:12px;display:inline-block}.badge.pending{background:#463514;color:#ffd27d}.badge.completed{background:#15331a;color:#a2f0b1}
        .form-inline{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}
        @media(max-width:980px){.summary-grid,.detail-grid{grid-template-columns:1fr}}
        @media(max-width:820px){.sidebar{position:static;width:100%;height:auto}.dashboard-container{display:block}.main{margin-left:0;width:100%;padding:16px}header{flex-direction:column;align-items:flex-start;gap:12px}}
    </style>
</head>
<body>
<div class="dashboard-container">
    <aside class="sidebar">
        <div class="logo"><a href="/">Contrataê</a></div>
        <ul>
            <li><a href="/" class="nav-link"><i class="fas fa-home"></i> Início</a></li>
            <li><a href="#" class="nav-link" data-tab="resumo"><i class="fas fa-chart-line"></i> Resumo</a></li>
            <li><a href="#" class="nav-link" data-tab="servicos"><i class="fas fa-briefcase"></i> Meus Serviços</a></li>
            <li><a href="#" class="nav-link" data-tab="avaliacoes"><i class="fas fa-star"></i> Avaliações</a></li>
            <li><a href="#" class="nav-link" data-tab="perfil"><i class="fas fa-user"></i> Meu Perfil</a></li>
            <li><a href="#" class="nav-link" data-tab="portfolio"><i class="fas fa-image"></i> Meu Portfólio</a></li>
            <li><a href="#" class="nav-link" data-tab="planos"><i class="fas fa-credit-card"></i> Meu Plano</a></li>
            <li><a href="#" class="nav-link" data-tab="pagamentos"><i class="fas fa-money-check"></i> Pagamentos</a></li>
            <li><a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Sair</a></li>
        </ul>
    </aside>

    <main class="main">
        <header>
            <div>
                <h1>Dashboard do Profissional</h1>
                <div class="small">Gerencie seu perfil, portfólio e ativação da sua presença na plataforma.</div>
            </div>
            <div class="user-chip">
                <div><%= fullName || 'Profissional' %></div>
                <div class="avatar">
                    <% if (profissional?.users?.avatar_url) { %><img src="<%= profissional.users.avatar_url %>" alt="Avatar"><% } else { %><%= (fullName || 'P').charAt(0).toUpperCase() %><% } %>
                </div>
            </div>
        </header>

        <% if (flashError) { %><div class="flash error"><%= flashError %></div><% } %>
        <% if (flashSuccess) { %><div class="flash success"><%= flashSuccess %></div><% } %>

        <% if (!profileReadyForApproval) { %>
            <div class="banner">
                <h3>Seu perfil ainda não está pronto para aparecer no site</h3>
                <p>Finalize o onboarding para definir plano, profissões, descrição e imagens. Depois disso, você poderá revisar tudo com calma e só então solicitar aprovação.</p>
                <div class="top-actions">
                    <a href="/profissional/onboarding?step=1" class="btn btn-primary">Continuar onboarding</a>
                    <form action="/auth/cancelar-profissional" method="POST"><button class="btn btn-secondary" type="submit">Cancelar cadastro</button></form>
                </div>
            </div>
        <% } else { %>
            <div class="banner">
                <h3>Seu perfil está pronto para a próxima etapa</h3>
                <p>Revise as informações abaixo. Quando estiver satisfeito, envie seu perfil para análise da plataforma.</p>
                <div class="top-actions">
                    <a href="/profissional/onboarding?step=1" class="btn btn-secondary">Editar onboarding</a>
                    <form action="/profissional/solicitar-aprovacao" method="POST"><button class="btn btn-primary" type="submit">Solicitar aprovação</button></form>
                </div>
            </div>
        <% } %>

        <section id="resumo" class="tab-content">
            <div class="cards-grid">
                <div class="card metric"><div class="icon"><i class="fas fa-phone"></i></div><h3>Contatos Recebidos</h3><div class="value"><%= contatosRecebidos %></div></div>
                <div class="card metric"><div class="icon"><i class="fas fa-check-circle"></i></div><h3>Serviços Concluídos</h3><div class="value"><%= servicosConcluidos %></div></div>
                <div class="card metric"><div class="icon"><i class="fas fa-money-bill-wave"></i></div><h3>Faturamento (Mês)</h3><div class="value">R$ <%= faturamentoMes %></div></div>
                <div class="card metric"><div class="icon"><i class="fas fa-star"></i></div><h3>Avaliação Média</h3><div class="value"><%= avaliacaoMedia %></div></div>
            </div>
            <div class="summary-grid" style="margin-top:18px;">
                <div class="panel">
                    <h2>Andamento do perfil</h2>
                    <div class="detail-grid" style="margin-top:14px;">
                        <div class="detail"><strong>Dados básicos</strong><%= basicProfileComplete ? 'Concluídos' : 'Pendentes' %></div>
                        <div class="detail"><strong>Plano atual</strong><%= currentPlanName %></div>
                        <div class="detail"><strong>Profissões escolhidas</strong><%= selectedCount %></div>
                        <div class="detail"><strong>Portfólio</strong><%= (portfolio || []).length %> imagem(ns)</div>
                    </div>
                </div>
                <div class="panel">
                    <h2>Próximo passo</h2>
                    <p class="small" style="margin-top:8px;">Use o onboarding separado para evoluir seu perfil sem cair em formulários confusos dentro da dashboard.</p>
                    <div class="top-actions"><a href="/profissional/onboarding?step=1" class="btn btn-primary">Abrir onboarding</a></div>
                </div>
            </div>
        </section>

        <section id="perfil" class="tab-content">
            <div class="panel">
                <h2>Meu Perfil Profissional</h2>
                <p class="small">Aqui fica a visão geral do perfil já salvo. Para editar, use o onboarding separado.</p>
                <div class="detail-grid" style="margin-top:14px;">
                    <div class="detail"><strong>Nome</strong><%= profissional?.users?.full_name || fullName || 'Não informado' %></div>
                    <div class="detail"><strong>Telefone</strong><%= profissional.phone_number || 'Não informado' %></div>
                    <div class="detail"><strong>Cidade / Estado</strong><%= profissional.city ? `${profissional.city} - ${profissional.state || ''}` : 'Não informado' %></div>
                    <div class="detail"><strong>CEP</strong><%= profissional.cep || 'Não informado' %></div>
                </div>
                <div class="detail" style="margin-top:12px;"><strong>Descrição</strong><%= profissional.description || 'Ainda não adicionada.' %></div>
                <div class="detail" style="margin-top:12px;"><strong>Profissão principal</strong><%= currentPrimaryCategory?.name || 'Ainda não definida' %></div>
                <div class="chip-wrap">
                    <% if ((selectedAdditionalCategories || []).length) { %>
                        <% selectedAdditionalCategories.forEach(cat => { %><span class="chip"><%= cat.name %></span><% }) %>
                    <% } else { %>
                        <span class="chip">Sem profissões adicionais</span>
                    <% } %>
                </div>
                <div class="detail" style="margin-top:12px;"><strong>Especialidades</strong><%= profissional.specialties || 'Não informadas' %></div>
                <div class="detail" style="margin-top:12px;"><strong>Disponibilidade</strong><%= profissional.availability || 'Não informada' %></div>
                <div class="detail" style="margin-top:12px;"><strong>Preço</strong><%= profissional.price_info || 'Não informado' %></div>
                <div class="top-actions"><a href="/profissional/onboarding?step=1" class="btn btn-primary">Editar perfil</a></div>
            </div>
        </section>

        <section id="portfolio" class="tab-content">
            <div class="panel">
                <h2>Meu Portfólio</h2>
                <p class="small" style="margin-bottom:14px;">Adicione mais fotos dos seus melhores trabalhos. Aqui é o lugar de revisar, excluir e complementar seu material.</p>
                <form action="/profissional/portfolio/adicionar" method="POST" enctype="multipart/form-data" class="form-inline">
                    <input type="file" name="portfolio_images" accept="image/*" multiple required>
                    <button type="submit" class="btn btn-primary">Adicionar ao portfólio</button>
                </form>
                <div class="portfolio-grid">
                    <% if ((portfolio || []).length) { %>
                        <% portfolio.forEach(item => { %>
                            <div class="portfolio-thumb">
                                <img src="<%= item.image_url %>" alt="Portfólio">
                                <form action="/profissional/portfolio/remover" method="POST" style="position:absolute;top:10px;right:10px;">
                                    <input type="hidden" name="id" value="<%= item.id %>">
                                    <button class="btn btn-danger" type="submit" style="padding:7px 10px;">Remover</button>
                                </form>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="small">Nenhuma foto no portfólio ainda.</p>
                    <% } %>
                </div>
            </div>
        </section>

        <section id="planos" class="tab-content">
            <div class="panel">
                <h2>Meu Plano</h2>
                <p class="small">Seu plano atual é definido no onboarding. Hoje você está no <strong><%= currentPlanName %></strong>.</p>
                <div class="top-actions">
                    <a href="/profissional/onboarding?step=1" class="btn btn-primary">Mudar plano</a>
                </div>
                <div class="detail-grid" style="margin-top:14px;">
                    <div class="detail"><strong>Profissões liberadas</strong><%= selectedCount || 1 %></div>
                    <div class="detail"><strong>Status do perfil</strong><%= profileReadyForApproval ? 'Pronto para análise' : 'Em montagem' %></div>
                    <div class="detail"><strong>Pagamento</strong>Definido na próxima etapa</div>
                    <div class="detail"><strong>Dica</strong>Mais categorias tendem a gerar mais contatos</div>
                </div>
            </div>
        </section>

        <section id="pagamentos" class="tab-content">
            <div class="panel">
                <h2>Histórico de Pagamentos</h2>
                <div class="table-wrap" style="margin-top:14px;">
                    <table>
                        <thead><tr><th>Data</th><th>Plano</th><th>Valor</th><th>Status</th></tr></thead>
                        <tbody>
                            <% if ((pagamentos || []).length) { %>
                                <% pagamentos.forEach(pag => { %>
                                    <tr>
                                        <td><%= new Date(pag.payment_date).toLocaleDateString('pt-BR') %></td>
                                        <td><%= pag.plans?.name || 'Plano' %></td>
                                        <td>R$ <%= pag.amount %></td>
                                        <td><span class="badge <%= pag.status %>"><%= pag.status === 'completed' ? 'Concluído' : 'Pendente' %></span></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="4" class="small">Nenhum pagamento registrado ainda.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section id="servicos" class="tab-content"><div class="panel"><h2>Meus Serviços</h2><p class="small">Essa área entra na próxima fase do produto, depois que o onboarding estiver 100% redondo.</p></div></section>
        <section id="avaliacoes" class="tab-content"><div class="panel"><h2>Avaliações</h2><p class="small">Essa área entra na próxima fase do produto, com histórico, notas e evolução do perfil.</p></div></section>
    </main>
</div>
<script>
const activeTab = '<%= activeTab || "resumo" %>';
function openTab(tab){
    document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.nav-link[data-tab]').forEach(el => el.classList.remove('active'));
    const panel = document.getElementById(tab); if(panel) panel.classList.add('active');
    const link = document.querySelector(`.nav-link[data-tab="${tab}"]`); if(link) link.classList.add('active');
    history.replaceState({}, '', `/profissional/dashboard?tab=${tab}`);
}
document.addEventListener('DOMContentLoaded', ()=>{
    document.querySelectorAll('.nav-link[data-tab]').forEach(link => link.addEventListener('click', ev => { ev.preventDefault(); openTab(link.dataset.tab); }));
    openTab(activeTab || 'resumo');
});
</script>
</body>
</html>
