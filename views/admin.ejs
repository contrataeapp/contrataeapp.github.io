<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contrataê - Gestão ADM v2.0</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
</head>
<body>
    <div class="dashboard-wrapper">
        <aside class="sidebar">
            <div class="logo"><a href="/">Contrataê</a></div>
            <nav>
                <ul>
                    <li><a href="#dashboard" class="active"><i class="fas fa-chart-line"></i> Dashboard</a></li>
                    <li><a href="#profissionais"><i class="fas fa-tools"></i> Profissionais</a></li>
                    <li><a href="#banners"><i class="fas fa-ad"></i> Banners</a></li>
                    <li><a href="#comentarios"><i class="fas fa-star"></i> Moderação</a></li>
                    <li><a href="#relatorios"><i class="fas fa-file-pdf"></i> Relatórios</a></li>
                    <li><a href="#mensagens"><i class="fas fa-envelope"></i> Mensagens</a></li>
                    <li><a href="#notificacoes"><i class="fas fa-bell"></i> Notificações</a></li>
                    <li><a href="#configuracoes"><i class="fas fa-cog"></i> Configurações</a></li>
                    <li><a href="/logout-adm"><i class="fas fa-power-off"></i> Sair</a></li>
                </ul>
            </nav>
        </aside>

        <div class="main-content">
            <header>
                <button id="mobile-sidebar-trigger" class="mobile-only" style="background:none; border:none; font-size:1.5rem; color:var(--primary); cursor:pointer; margin-right:15px;">
                    <i class="fas fa-bars"></i>
                </button>
                <h1>Painel de Controle</h1>
                <div class="user-info">
                    <span>Administrador</span>
                    <div class="avatar">ADM</div>
                </div>
            </header>

            <section class="admin-section active" id="dashboard">
                <div class="section-header">
                    <h2>Resumo do Sistema</h2>
                </div>
              
                <div class="summary-cards">
                    <div class="card finance">
                        <div class="icon"><i class="fas fa-wallet"></i></div>
                        <div class="details">
                            <h3>Receita Total</h3>
                            <p>R$ <%= typeof totais !== 'undefined' ? totais.receitaTotal.toFixed(2).replace('.', ',') : '0,00' %></p>
                        </div>
                    </div>
 
                    <div class="card monthly">
                        <div class="icon"><i class="fas fa-calendar-alt"></i></div>
                        <div class="details">
                            <h3>Este Mês</h3>
                            <p>R$ <%= typeof totais !== 'undefined' ? totais.receitaMes.toFixed(2).replace('.', ',') : '0,00' %></p>
                        </div>
                    </div>
      
                    <div class="card active-users">
                        <div class="icon"><i class="fas fa-check-circle"></i></div>
                        <div class="details">
                            <h3>Ativos</h3>
                            <p><%= typeof totais !== 'undefined' ? totais.ativos : '0' %></p>
                        </div>
                    </div>
                    <div class="card pending-users">
                        <div class="icon"><i class="fas fa-clock"></i></div>
                        <div class="details">
                            <h3>Pendentes</h3>
                            <p><%= typeof totais !== 'undefined' ? totais.pendentes : '0' %></p>
                        </div>
                    </div>
                    <div class="card paused-users">
                        <div class="icon"><i class="fas fa-pause-circle"></i></div>
                        <div class="details">
                            <h3>Pausados</h3>
                            <p><%= typeof totais !== 'undefined' ? totais.pausados : '0' %></p>
                        </div>
                    </div>
                </div>
            </section>

            <section class="admin-section" id="profissionais">
                <div class="section-header">
                    <h2>Gestão de Profissionais</h2>
                    <div class="section-controls">
                        <input type="text" id="busca" class="search-input" placeholder="Buscar..." value="<%= typeof filtroAtivo !== 'undefined' ? filtroAtivo.busca || '' : '' %>">
                    </div>
                </div>

                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>Profissional</th>
                                <th>Categoria</th>
                                <th>Status</th>
                                <th>Vencimento</th>
                                <th>Valor Pago</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody id="tabela-profissionais">
                            <% if (typeof profissionais === 'undefined' || profissionais.length === 0) { %>
                                <tr>
                                    <td colspan="6" style="text-align: center; color: #999;">Nenhum profissional encontrado</td>
                                </tr>
                            <% } else { %>
                                <% profissionais.forEach(function(p) { %>
                                    <tr class="profissional-row" data-id="<%= p.id %>">
                                        <td>
                                            <div class="profissional-info">
                                                <img src="<%= p.photo_url || '/imagens/equipe_site/Mascote.png' %>" alt="<%= p.users.full_name %>" class="avatar-mini">
                                                <div>
                                                    <strong><%= p.users.full_name %></strong>
                                                    <small style="color: #666;"><i class="fas fa-envelope"></i> <%= p.users.email %></small>
                                                </div>
                                            </div>
                                        </td>
                                        <td><%= p.categories ? p.categories.name : 'N/A' %></td>
                                        <td>
                                            <span class="badge <%= p.status %>">
                                                <%= p.status.toUpperCase() %>
                                            </span>
                                        </td>
                                        <td><%= p.plan_expires_at ? new Date(p.plan_expires_at).toLocaleDateString('pt-BR') : 'N/A' %></td>
                                        <td>R$ <%= p.payment_value ? p.payment_value.toFixed(2).replace('.', ',') : '0,00' %></td>
                                        <td>
                                            <div class="action-buttons">
                                                <% if (p.status === 'pending') { %>
                                                    <button class="btn-action approve" onclick="abrirModalAprovacao('<%= p.id %>')"><i class="fas fa-check"></i></button>
                                                <% } %>
                                                <button class="btn-action edit" onclick="abrirModalEdicao('<%= p.id %>')"><i class="fas fa-edit"></i></button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>
    <script src="/js/admin.js"></script>
</body>
</html>
